# ══════════════════════════════════════════════════════════════════════════════
# Pipely AI — Environment Variables
# Copy this file: cp .env.example .env
# Then edit the values below
# ══════════════════════════════════════════════════════════════════════════════

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
# Used by docker-compose to create the database container
DB_USER=pipely
DB_PASSWORD=pipely123
DB_NAME=pipely_ai

# ─── Security ────────────────────────────────────────────────────────────────
# Leave empty to auto-generate on first start
JWT_SECRET=

# ─── URLs ────────────────────────────────────────────────────────────────────
# Your domain or VPS IP (used for CORS and invite links)
# Examples: https://pipely.yourdomain.com  or  http://123.45.67.89
APP_URL=http://localhost

# ─── Agent ───────────────────────────────────────────────────────────────────
# How often the agent checks for tasks to process (in milliseconds)
POLL_INTERVAL_MS=60000

# ─── Port ────────────────────────────────────────────────────────────────────
# Port exposed on your VPS (default: 80)
APP_PORT=80
