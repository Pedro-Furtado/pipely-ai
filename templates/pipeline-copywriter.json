      "color": "blue",
      "position": 0,
      "blocks": [
        {
          "name": "Novo Pedido",
          "slug": "novo_pedido",
          "blockType": "message",
          "config": {
            "prompt": "Notifique o responsavel sobre a nova tarefa com os detalhes e confirme se ele entendeu o briefing",
            "branches": [
              {
                "label": "Briefing entendido",
                "nextSlug": "__briefing_recebido__",
                "condition": "Responsavel confirmou que entendeu a tarefa"
